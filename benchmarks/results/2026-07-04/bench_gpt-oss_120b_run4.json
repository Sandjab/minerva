  "moments": [
    {
      "id": 1,
      "chunk_index": 0,
      "seq": 0,
      "summary": "Jean Valjean arrive à Digne, les auberges le refusent, l’évêque Myriel (monseigneur Bienvenu) l’accueille et lui offre couverts et lit ; dans la nuit Valjean vole l’argenterie, est arrêté par les gendarmes et ramené devant Myriel qui déclare lui avoir donné les couverts et ajoute deux chandeliers d’argent.",
      "resolved_order": 0,
      "resolved_days": 0.0
    },
    {
      "id": 2,
      "chunk_index": 1,
      "seq": 0,
      "summary": "Des années plus tard, Jean Valjean sous le nom de M. Madeleine dirige une fabrique de perles noires à Montreuil‑sur‑Mer où il devient maire, tandis que l’inspecteur Javert le soupçonne.",
      "resolved_order": 1,
      "resolved_days": null
    },
    {
      "id": 3,
      "chunk_index": 2,
      "seq": 0,
      "summary": "Fantine confie sa fille Cosette aux Thénardier, subit la misère et reçoit la promesse de Jean Valjean (M. Madeleine) de veiller sur elle.",
      "resolved_order": 2,
      "resolved_days": null
    },
    {
      "id": 4,
      "chunk_index": 2,
      "seq": 1,
      "summary": "Après la mort de Fantine, Jean Valjean est démasqué par Javert, s’échappe, achète Cosette aux Thénardier la veille de Noël et l’installe à Paris comme sa fille.",
      "resolved_order": 3,
      "resolved_days": null
    }
  ],
