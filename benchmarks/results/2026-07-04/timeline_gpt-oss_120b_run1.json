  "moments": [
    {
      "id": 1,
      "chunk_index": 0,
      "seq": 0,
      "summary": "Élise Chardon rencontre le garçon Bastien Malot qui demande à devenir apprenti dans son atelier de lutherie.",
      "resolved_order": 1,
      "resolved_days": null
    },
    {
      "id": 2,
      "chunk_index": 1,
      "seq": 0,
      "summary": "Élise revit son enfance à douze ans dans la maison de son grand‑père Aurélien Chardon à Mirecourt, où il lui offre un canif à manche de buis.",
      "resolved_order": 0,
      "resolved_days": 0.0
    },
    {
      "id": 3,
      "chunk_index": 1,
      "seq": 1,
      "summary": "De retour à l’atelier, le carillon de la porte interrompt les souvenirs d’Élise ; Bastien vient de fendre une volute, elle ramasse les morceaux, sourit et repose le canif sur l’établi entre eux.",
      "resolved_order": 2,
      "resolved_days": null
    },
    {
      "id": 4,
      "chunk_index": 2,
      "seq": 0,
      "summary": "Vingt ans plus tard, Élise Chardon ferme la porte de la rue des Grilles une dernière fois, laisse le canif d'Aurélien sur l'établi avec un mot pour Bastien, puis prend le train vers Mirecourt ; Bastien Malot, devenu maître‑luthier, reprend l’atelier d’Aubervilliers.",
      "resolved_order": 3,
      "resolved_days": null
    },
    {
      "id": 5,
      "chunk_index": 2,
      "seq": 1,
      "summary": "Au même moment, à Lyon, l’archetière Camille Roche décachette une lettre de Bastien proposant une association entre les archets de Roche et les violons de la rue des Grilles ; elle regarde la Saône depuis son atelier de la Croix‑Rousse et répond qu’elle arrivera au printemps.",
      "resolved_order": 4,
      "resolved_days": null
    }
  ],
