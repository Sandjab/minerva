  "moments": [
    {
      "id": 1,
      "chunk_index": 0,
      "seq": 0,
      "summary": "Jean Valjean arrive à Digne après dix-neuf ans de bagne ; rejeté par les auberges à cause de son passeport jaune, il est accueilli par l’évêque Myriel.",
      "resolved_order": 0,
      "resolved_days": 0.0
    },
    {
      "id": 2,
      "chunk_index": 0,
      "seq": 1,
      "summary": "Valjean vole l’argenterie, fuir, est arrêté, et conduit devant l’évêque qui le disculpe en affirmant avoir donné les objets + deux chandeliers.",
      "resolved_order": 1,
      "resolved_days": null
    },
    {
      "id": 3,
      "chunk_index": 1,
      "seq": 0,
      "summary": "Vingt ans plus tard : Jean Valjean, sous l’identité d’urbanisée M. Madeleine, devient maire de Montreuil-sur-Mer après avoir prospéré avec une fabrique de perles noires ; l’inspecteur Javert soupçonne son passé de forçat.",
      "resolved_order": 2,
      "resolved_days": null
    },
    {
      "id": 4,
      "chunk_index": 2,
      "seq": 0,
      "summary": "Fantine confie Cosette aux Thénardier, la vend pour la payer, puis meurt en obtenant de M. Madeleine une promesse de Protection de Cosette.",
      "resolved_order": 3,
      "resolved_days": null
    },
    {
      "id": 5,
      "chunk_index": 2,
      "seq": 1,
      "summary": "Valjean, démasqué au procès de Champmathieu, s’échappe et va secourir Cosette à Montfermeil pour l’emmener à Paris.",
      "resolved_order": 4,
      "resolved_days": null
    }
  ],
