  "moments": [
    {
      "id": 1,
      "chunk_index": 0,
      "seq": 0,
      "summary": "Jean Valjean arrive à Digne le soir d’octobre, est accueilli par l’évêque Myriel, reçoit couvert et lit, vole l’argenterie pendant la nuit, est arrêté par les gendarmes et ramené devant Myriel qui déclare lui avoir donné les couverts et ajoute deux chandeliers d’argent.",
      "resolved_order": 0,
      "resolved_days": 0.0
    },
    {
      "id": 2,
      "chunk_index": 1,
      "seq": 0,
      "summary": "Jean Valjean, sous le nom de M. Madeleine, dirige une fabrique de perles noires à Montreuil‑sur‑Mer, devient maire et est soupçonné par l’inspecteur Javert.",
      "resolved_order": 1,
      "resolved_days": null
    },
    {
      "id": 3,
      "chunk_index": 2,
      "seq": 0,
      "summary": "Fantine confie sa petite fille Cosette aux époux Thénardier, subit la misère et reçoit la promesse de M. Madeleine de veiller sur elle.",
      "resolved_order": 2,
      "resolved_days": null
    },
    {
      "id": 4,
      "chunk_index": 2,
      "seq": 1,
      "summary": "Après la mort de Fantine, Jean Valjean, démasqué par Javert au procès de Champmathieu, se rend à Montfermeil, achète Cosette aux Thénardier la veille de Noël et s’installe avec elle à Paris où il l’élève comme sa propre fille.",
      "resolved_order": 3,
      "resolved_days": null
    }
  ],
