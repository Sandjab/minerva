  "moments": [
    {
      "id": 1,
      "chunk_index": 0,
      "seq": 0,
      "summary": "Jean Valjean arrive à Digne un soir d’octobre après dix-neuf ans de bagne, est rejeté par les auberges en raison de son passeport jaune, puis accueilli par l’évêque Myriel.",
      "resolved_order": 0,
      "resolved_days": 0.0
    },
    {
      "id": 2,
      "chunk_index": 0,
      "seq": 1,
      "summary": "Jean Valjean vola l’argenterie de l’évêque la nuit même, s’enfuit, fut arrêté par les gendarmes et ramené devant l’évêque, qui lui offrit en réalité les couverts et deux chandeliers d’argent.",
      "resolved_order": 1,
      "resolved_days": null
    },
    {
      "id": 3,
      "chunk_index": 1,
      "seq": 0,
      "summary": "Vingt ans plus tard : Jean Valjean, sous l’identité d’un homme prospère nommé M. Madeleine, dirige unefabrique de perles noires à Montreuil-sur-Mer et en est devenu maire ; l’inspecteur Javert le soupçonne.",
      "resolved_order": 2,
      "resolved_days": null
    },
    {
      "id": 4,
      "chunk_index": 2,
      "seq": 0,
      "summary": "Fantine confie Cosette aux Thénardier, se dégrade moralement et physique pour payer leur pension ; M. Madeleine lui promet de veiller sur Cosette avant sa mort.",
      "resolved_order": 3,
      "resolved_days": null
    },
    {
      "id": 5,
      "chunk_index": 2,
      "seq": 1,
      "summary": "Jean Valjean, démasqué puis échappé de Javert au procès de Champmathieu, se rend à Montfermeil, rachète Cosette aux Thénardier pour 1 500 francs et l’emporte à Paris pour l’élever comme sa fille.",
      "resolved_order": 4,
      "resolved_days": null
    }
  ],
