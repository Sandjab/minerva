  "moments": [
    {
      "id": 1,
      "chunk_index": 0,
      "seq": 0,
      "summary": "Élise Chardon, âgée de trente ans, reçoit la visite d’un garçon maigre, Bastien Malot, seize ans, envoyé par l’école Boulle qui demande à devenir son apprenti ; elle lui tend une gouge sans dire un mot.",
      "resolved_order": 1,
      "resolved_days": null
    },
    {
      "id": 2,
      "chunk_index": 1,
      "seq": 0,
      "summary": "Flashback : Élise revit l’hiver de ses douze ans chez son grand‑père Aurélien, à Mirecourt.",
      "resolved_order": 0,
      "resolved_days": 0.0
    },
    {
      "id": 3,
      "chunk_index": 1,
      "seq": 1,
      "summary": "Retour au présent : Bastien, trop nerveux, vient de fendre une volute ; Élise ramasse les morceaux et pose le canif sur l’établi entre eux deux.",
      "resolved_order": 2,
      "resolved_days": null
    },
    {
      "id": 4,
      "chunk_index": 2,
      "seq": 0,
      "summary": "Vingt ans plus tard, Élise Chardon (50 ans) ferme la porte de la rue des Grilles, laisse le canif d'Aurélien sur l'établi, Bastien Malot reprend l'atelier d'Aubervilliers et elle prend le train pour Mirecourt où l’attend la maison d’Aurélien.",
      "resolved_order": 3,
      "resolved_days": null
    },
    {
      "id": 5,
      "chunk_index": 2,
      "seq": 1,
      "summary": "Au même moment, à Lyon, l'archetière Camille Roche lit la lettre de Bastien proposant une association ; elle regarde la Saône depuis son atelier de la Croix‑Rousse et répond qu’elle arrivera au printemps.",
      "resolved_order": 4,
      "resolved_days": null
    }
  ],
