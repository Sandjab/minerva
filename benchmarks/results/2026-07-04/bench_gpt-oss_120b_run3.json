  "moments": [
    {
      "id": 1,
      "chunk_index": 0,
      "seq": 0,
      "summary": "Jean Valjean arrive à Digne un soir d’octobre, se voit refuser l’hospitalité des auberges à cause de son passeport jaune, est accueilli par l’évêque Myriel qui lui offre le couvert et le lit ; pendant la nuit il vole l’argenterie de l’évêque, est arrêté par les gendarmes, ramené devant Myriel qui déclare lui avoir donné les couverts et y ajoute deux chandeliers d’argent.",
      "resolved_order": 0,
      "resolved_days": 0.0
    },
    {
      "id": 2,
      "chunk_index": 1,
      "seq": 0,
      "summary": "M. Madeleine (Jean Valjean) dirige une fabrique de perles noires à Montreuil‑sur‑Mer, devient maire de la ville, l’inspecteur Javert y sert et le soupçonne en raison de sa force herculéenne.",
      "resolved_order": 1,
      "resolved_days": null
    },
    {
      "id": 3,
      "chunk_index": 2,
      "seq": 0,
      "summary": "Fantine confie sa fille Cosette aux Thénardier, vend ses cheveux et dents pour la pension, puis reçoit la promesse de Jean Valjean de veiller sur elle.",
      "resolved_order": 2,
      "resolved_days": null
    },
    {
      "id": 4,
      "chunk_index": 2,
      "seq": 1,
      "summary": "Après la mort de Fantine, Jean Valjean (démasqué par Javert) s’échappe, se rend à Montfermeil, achète Cosette aux Thénardier et s’installe avec elle à Paris.",
      "resolved_order": 3,
      "resolved_days": null
    }
  ],
