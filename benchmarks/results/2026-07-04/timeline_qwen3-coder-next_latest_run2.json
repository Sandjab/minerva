  "moments": [
    {
      "id": 1,
      "chunk_index": 0,
      "seq": 0,
      "summary": "Présentation d’Élise Chardon dans son atelier de lutherie à Aubervilliers, suivie de l’entrée de Bastien Malot qui demande à être apprenti et subit un test silencieux.",
      "resolved_order": 1,
      "resolved_days": null
    },
    {
      "id": 2,
      "chunk_index": 1,
      "seq": 0,
      "summary": "Élise est transportée dans un souvenir d’enfance à Mirecourt avec son grand-père Aurélien Chardon ; àson retour au présent, Bastien vient de casser une volute, et Élise propose de recommencer en lui rappelant les paroles de son grand-père.",
      "resolved_order": 0,
      "resolved_days": 0.0
    },
    {
      "id": 3,
      "chunk_index": 1,
      "seq": 1,
      "summary": "Retour au présent : Bastien, trop nerveux, vient de fissurer une volute ; Élise ramasse les morceaux, sourit, place le canif de buis entre eux et répète la maxime de son grand-père en l’appliquant aux mains humaines.",
      "resolved_order": 2,
      "resolved_days": null
    },
    {
      "id": 4,
      "chunk_index": 2,
      "seq": 0,
      "summary": "Vingt ans plus tard : Élise ferme définitivement son atelier de la rue des Grilles, léguant le canif d’Aurélien à Bastien devenu maître luthier, puis part pour Mirecourt.",
      "resolved_order": 3,
      "resolved_days": null
    },
    {
      "id": 5,
      "chunk_index": 2,
      "seq": 1,
      "summary": "Scène parallèle simultanée : Camille Roche, à Lyon, lit une proposition d’association de Bastien et accepte à l’issue d’un long silence contemplatif.",
      "resolved_order": 4,
      "resolved_days": null
    }
  ],
