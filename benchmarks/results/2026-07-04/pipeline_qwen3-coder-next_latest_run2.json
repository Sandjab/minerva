    },
    {
      "id": 4,
      "chunk_index": 1,
      "seq": 0,
      "summary": "Vingt ans plus tard : Jean Valjean, sous l’identité déménagée de M. Madeleine, est maire de Montreuil-sur-Mer et chef d’une fabrique de perles noires ; Javert, soupçonneux, le croirait lié au bagne.",
      "resolved_order": 3,
      "resolved_days": null
    },
    {
      "id": 5,
      "chunk_index": 2,
      "seq": 0,
      "summary": "Fantine confie Cosette aux Thénardier, subit la misère, vend ses cheveux et dents, puis meurt après avoir obtenu de M. Madeleine la promesse de s’occuper de Cosette.",
      "resolved_order": 4,
      "resolved_days": null
    },
    {
      "id": 6,
      "chunk_index": 2,
      "seq": 1,
      "summary": "Jean Valjean, démasqué par Javert lors du procès de Champmathieu, s’échappe et se rend à Montfermeil pour arracher Cosette aux Thénardier.",
      "resolved_order": 5,
      "resolved_days": null
    },
    {
      "id": 7,
      "chunk_index": 2,
      "seq": 2,
      "summary": "Jean Valjean rachète Cosette aux Thénardier pour 1 500Francs la veille de Noël, et s’installe avec elle à Paris où il l’éduit comme sa fille.",
      "resolved_order": 6,
      "resolved_days": null
    }
