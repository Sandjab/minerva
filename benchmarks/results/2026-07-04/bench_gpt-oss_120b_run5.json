  "moments": [
    {
      "id": 1,
      "chunk_index": 0,
      "seq": 0,
      "summary": "Jean Valjean arrive à Digne, est hébergé par l'évêque Myriel, vole les objets sacrés, est arrêté et présenté de nouveau à Myriel.",
      "resolved_order": 0,
      "resolved_days": 0.0
    },
    {
      "id": 2,
      "chunk_index": 1,
      "seq": 0,
      "summary": "Des années plus tard, Jean Valjean, sous le nom de M. Madeleine, dirige une fabrique à Montreuil‑sur‑Mer et y devient maire ; l’inspecteur Javert, policier de la ville, le suspecte.",
      "resolved_order": 1,
      "resolved_days": null
    },
    {
      "id": 3,
      "chunk_index": 2,
      "seq": 0,
      "summary": "Fantine confie sa fille Cosette aux époux Thénardier, subit la misère et vend ses cheveux et dents pour payer la pension de l’enfant ; elle reçoit la promesse de M. Madeleine de veiller sur Cosette. Après la mort de Fantine, Jean Valjean est démasqué par Javert au procès de Champmathieu, s’échappe, paie 1 500 francs aux Thénardier pour reprendre Cosette la veille de Noël, puis s’installe à Paris où il l’élève comme sa propre fille.",
      "resolved_order": 2,
      "resolved_days": null
    }
  ],
