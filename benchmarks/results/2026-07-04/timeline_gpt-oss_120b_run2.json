    {
      "id": 2,
      "chunk_index": 1,
      "seq": 0,
      "summary": "Flashback : Élise, alors âgée de douze ans, se trouve chez son grand‑père Aurélien à Mirecourt où il lui offre son premier canif.",
      "resolved_order": 0,
      "resolved_days": 0.0
    },
    {
      "id": 3,
      "chunk_index": 1,
      "seq": 1,
      "summary": "Retour au présent : Bastien, nerveux, vient de fendre une volute ; Élise ramasse les morceaux et repose le canif sur l'établi entre eux.",
      "resolved_order": 2,
      "resolved_days": null
    },
    {
      "id": 4,
      "chunk_index": 2,
      "seq": 0,
      "summary": "Vingt ans plus tard, Élise ferme la porte de l'atelier, laisse le canif d'Aurélien et part en train pour Mirecourt ; Bastien reprend l’atelier.",
      "resolved_order": 3,
      "resolved_days": null
    },
    {
