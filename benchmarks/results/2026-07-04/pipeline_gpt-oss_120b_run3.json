    {
      "id": 1,
      "chunk_index": 0,
      "seq": 0,
      "summary": "Jean Valjean arrive à Digne, est accueilli par l’évêque Myriel qui lui offre le couvert ; la nuit Valjean vole l’argenterie, est arrêté et ramené devant Myriel qui déclare avoir donné les couverts et deux chandeliers d’argent.",
      "resolved_order": 0,
      "resolved_days": 0.0
    },
    {
      "id": 2,
      "chunk_index": 1,
      "seq": 0,
      "summary": "Des années plus tard, M. Madeleine (Jean Valjean) dirige une fabrique de perles noires à Montreuil‑sur‑Mer et devient maire ; l’inspecteur Javert le soupçonne.",
      "resolved_order": 1,
      "resolved_days": null
    },
    {
      "id": 3,
      "chunk_index": 2,
      "seq": 0,
      "summary": "Fantine confie sa fille Cosette aux époux Thénardier, subit la misère et reçoit la promesse de Jean Valjean (M. Madeleine).",
      "resolved_order": 2,
      "resolved_days": null
    },
    {
      "id": 4,
      "chunk_index": 2,
      "seq": 1,
      "summary": "Après la mort de Fantine, Jean Valjean est démasqué par Javert, achète Cosette aux Thénardier et s’installe à Paris.",
      "resolved_order": 3,
      "resolved_days": null
    }
  ],
