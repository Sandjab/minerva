  "moments": [
    {
      "id": 1,
      "chunk_index": 0,
      "seq": 0,
      "summary": "Jean Valjean arrive à Digne en octobre, est rejeté par les auberges à cause de son passeport jaune, mais l’évêque Myriel (monseigneur Bienvenu) l’accueille, lui offre couvert et lit. Dans la nuit, Valjean vole l’argenterie de l’évêque, s’enfuit, est arrêté par les gendarmes, ramené devant Myriel qui déclare lui avoir donné les couverts et y ajoute deux chandeliers d’argent.",
      "resolved_order": 0,
      "resolved_days": 0.0
    },
    {
      "id": 2,
      "chunk_index": 1,
      "seq": 0,
      "summary": "Des années plus tard, M. Madeleine (qui n’est autre que Jean Valjean) dirige une fabrique de perles noires à Montreuil‑sur‑Mer, y devient maire, et l’inspecteur Javert, né dans une prison, sert dans la même ville et le soupçonne.",
      "resolved_order": 1,
      "resolved_days": null
    },
    {
      "id": 3,
      "chunk_index": 2,
      "seq": 0,
      "summary": "Fantine confie sa fille Cosette aux Thénardier, subit la misère et reçoit la promesse de Jean Valjean (M. Madeleine) de veiller sur sa fille avant de mourir.",
      "resolved_order": 2,
      "resolved_days": null
    },
    {
      "id": 4,
      "chunk_index": 2,
      "seq": 1,
      "summary": "Après la mort de Fantine, Jean Valjean, démasqué par Javert, se rend à Montfermeil, rachète Cosette aux Thénardier le soir de Noël et s’installe avec elle à Paris où il l’élève comme sa fille.",
      "resolved_order": 3,
      "resolved_days": null
    }
  ],
