  "moments": [
    {
      "id": 1,
      "chunk_index": 0,
      "seq": 0,
      "summary": "Jean Valjean arrive à Digne après dix-neuf ans de bagne et est rejeté par les auberges.",
      "resolved_order": 0,
      "resolved_days": 0.0
    },
    {
      "id": 2,
      "chunk_index": 0,
      "seq": 1,
      "summary": "À cause de son passeport jaune, les auberges refusent l'hébergement à Jean Valjean.",
      "resolved_order": 1,
      "resolved_days": null
    },
    {
      "id": 3,
      "chunk_index": 0,
      "seq": 2,
      "summary": "L'évêque Myriel accueille Jean Valjean chez lui.",
      "resolved_order": 2,
      "resolved_days": null
    },
    {
      "id": 4,
      "chunk_index": 0,
      "seq": 3,
      "summary": "Jean Valjean vole l’argenterie de l’évêque la nuit même.",
      "resolved_order": 3,
      "resolved_days": null
    },
    {
      "id": 5,
      "chunk_index": 0,
      "seq": 4,
      "summary": "Arrêté par les gendarmes, Jean Valjean est ramené devant l’évêque.",
      "resolved_order": 4,
      "resolved_days": null
    },
    {
      "id": 6,
      "chunk_index": 0,
      "seq": 5,
      "summary": "L’évêque sauve Jean Valjean en affirmant avoir offert l’argenterie et en lui donnant les chandeliers.",
      "resolved_order": 5,
      "resolved_days": null
    },
    {
      "id": 7,
      "chunk_index": 1,
      "seq": 0,
      "summary": "Vingt ans plus tard, Jean Valjean, sous l'identité d’Hippolyte Madeleine (dit M. Madeleine), dirige une fabrique de perles noires à Montreuil-sur-Mer et est élu mayor ; l’inspecteur Javert le soupçonne être un ancien forçat.",
      "resolved_order": 6,
      "resolved_days": null
    },
    {
      "id": 8,
      "chunk_index": 2,
      "seq": 0,
      "summary": "Fantine confie Cosette aux Thénardier, subit une dégradation sociale, et meurt après avoir obtenu de M. Madeleine la promesse de protectorat sur Cosette.",
      "resolved_order": 7,
      "resolved_days": null
    },
    {
      "id": 9,
      "chunk_index": 2,
      "seq": 1,
      "summary": "Les Thénardier maltraitent et exploitent Cosette comme une servante.",
      "resolved_order": 8,
      "resolved_days": null
    },
    {
      "id": 10,
      "chunk_index": 2,
      "seq": 2,
      "summary": "Fantine est renvoyée de la fabrique, tombe dans la misère et vend ses cheveux puis ses dents pour payer la pension de Cosette.",
      "resolved_order": 9,
      "resolved_days": null
    },
    {
      "id": 11,
      "chunk_index": 2,
      "seq": 3,
      "summary": "Mourante, Fantine obtient de M. Madeleine la promesse de veiller sur Cosette.",
      "resolved_order": 10,
      "resolved_days": null
    },
    {
      "id": 12,
      "chunk_index": 2,
      "seq": 4,
      "summary": "Après s’être échappé de nouveau et avoir dévoilé son identité au procès de Champmathieu, Jean Valjean se rend à Montfermeil pour sauver Cosette.",
      "resolved_order": 11,
      "resolved_days": null
    },
    {
      "id": 13,
      "chunk_index": 2,
      "seq": 5,
      "summary": "Jean Valjean paie 1500 francs aux Thénardier pour emmener Cosette la veille de Noël et l’installe à Paris où il l’éleve comme sa fille.",
      "resolved_order": 12,
      "resolved_days": null
    }
  ],
