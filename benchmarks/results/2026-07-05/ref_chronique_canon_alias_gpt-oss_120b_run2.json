  "moments": [
    {
      "id": 1,
      "chunk_index": 0,
      "seq": 0,
      "summary": "Annonce de l'ouverture de la médiathèque du Vieux Moulin le 14 juin et présentation du bâtiment restauré par la maire Hélène Fabre au conseil municipal.",
      "resolved_order": 0,
      "resolved_days": 0.0
    },
    {
      "id": 2,
      "chunk_index": 1,
      "seq": 0,
      "summary": "Le Vieux Moulin abandonné est sauvé par l’association Les Amis du Vieux Moulin, présidée par Raymond Fabre, père d’Hélène Fabre, avant son rachat par la municipalité.",
      "resolved_order": 1,
      "resolved_days": null
    },
    {
      "id": 3,
      "chunk_index": 2,
      "seq": 0,
      "summary": "Détails de la réhabilitation : architecte Nadia Berthelot, conservation de la grande roue à aubes, chantier mené par Delmas & Fils, coût de 2,4 M€, un tiers versé par la Région, et citation de l’architecte.",
      "resolved_order": 2,
      "resolved_days": null
    },
    {
      "id": 4,
      "chunk_index": 3,
      "seq": 0,
      "summary": "Débat au conseil municipal : le conseiller d’opposition Julien Roche vote contre le budget final et critique le coût de la roue décorative, la maire Hélène Fabre réplique en évoquant la fréquentation estimée à 400 visiteurs/semaine.",
      "resolved_order": 3,
      "resolved_days": null
    },
    {
      "id": 5,
      "chunk_index": 4,
      "seq": 0,
      "summary": "Sur la place du Marché les habitants donnent un avis nuancé ; Delmas & Fils embauche sept apprentis de Céredac pour le chantier ; Sophie Vasseur, bibliothécaire venue de la médiathèque voisine de Roquevert, dirigera une équipe de six personnes et promet une salle enfants au rez‑de‑chaussée ainsi qu’un fonds ancien à l’étage sous la charpente d’origine.",
      "resolved_order": 4,
      "resolved_days": null
    },
    {
      "id": 6,
      "chunk_index": 5,
      "seq": 0,
      "summary": "Le conseil municipal décide que l’équipement portera le nom « médiathèque Raymond‑Fabre », suite aux interventions de Raymond Fabre, Hélène Fabre et Julien Roche ; est annoncée l’inauguration du 14 juin suivie d’une semaine portes ouvertes, et la Sorgue continue à faire tourner la roue décorative.",
      "resolved_order": 5,
      "resolved_days": null
    }
  ],
