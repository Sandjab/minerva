  "moments": [
    {
      "id": 1,
      "chunk_index": 0,
      "seq": 0,
      "summary": "À Aubières, le docteur Étienne Mercier et la libraire Camille Mercier exercent chacun de leur côté ; le facteur remet les lettres adressées à « Mercier » selon leur contenu.",
      "resolved_order": 0,
      "resolved_days": 0.0
    },
    {
      "id": 2,
      "chunk_index": 1,
      "seq": 0,
      "summary": "Camille Mercier a pour amie l’institutrice Suzanne Vidal, surnommée la Demoiselle ; la Demoiselle passe ses jeudis à la librairie de Camille à corriger des cahiers près du poêle et dit que l’odeur du papier neuf l’aide à réfléchir. Le docteur Étienne Mercier la trouve trop pâle et lui recommande le grand air.",
      "resolved_order": 1,
      "resolved_days": null
    },
    {
      "id": 3,
      "chunk_index": 2,
      "seq": 0,
      "summary": "À Aubières, le domaine de Delorme appartient à Lucien Delorme qui élève des chèvres, presse du cidre et fournit du lait au docteur Étienne Mercier ; le domaine ne ferme jamais.",
      "resolved_order": 2,
      "resolved_days": null
    },
    {
      "id": 4,
      "chunk_index": 3,
      "seq": 0,
      "summary": "Un soir de novembre, la Demoiselle tousse fort en classe ; Étienne Mercier l'ausculte, lui prescribe un mois de repos au domaine de Delorme et est conduit là‑bas par Lucien Delorme.",
      "resolved_order": 3,
      "resolved_days": null
    },
    {
      "id": 5,
      "chunk_index": 3,
      "seq": 1,
      "summary": "Au printemps, Mlle Vidal rouvre la classe guérie ; les deux Mercier se félicitent chacun de leur côté comme s’ils formaient une même famille.",
      "resolved_order": 4,
      "resolved_days": null
    }
  ],
