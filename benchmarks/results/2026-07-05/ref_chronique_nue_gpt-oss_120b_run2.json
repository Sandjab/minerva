  "moments": [
    {
      "id": 1,
      "chunk_index": 0,
      "seq": 0,
      "summary": "Annonce de l'ouverture le 14 juin de la médiathèque du Vieux Moulin et présentation du bâtiment restauré par la maire Hélène Fabre au conseil municipal.",
      "resolved_order": 0,
      "resolved_days": 0.0
    },
    {
      "id": 2,
      "chunk_index": 1,
      "seq": 0,
      "summary": "Le Vieux Moulin est abandonné depuis la fermeture de la minoterie ; l'association Les Amis du Vieux Moulin, présidée par Raymond Fabre (père d’Hélène Fabre), a mené une lutte de dix ans de pétitions pour sauver le bâtiment et permettre à la municipalité de le racheter. Hélène Fabre, maire, souligne que son père a sauvé les murs et qu’ils y placeront des livres.",
      "resolved_order": 1,
      "resolved_days": null
    },
    {
      "id": 3,
      "chunk_index": 2,
      "seq": 0,
      "summary": "Réhabilitation confiée à Nadia Berthelot, conservation de la grande roue à aubes, chantier mené par Delmas & Fils coûtant 2,4 M€, un tiers financé par la Région et déclaration d’un parti‑pris par l’architecte.",
      "resolved_order": 2,
      "resolved_days": null
    },
    {
      "id": 4,
      "chunk_index": 3,
      "seq": 0,
      "summary": "Julien Roche, conseiller d'opposition, vote contre le budget final et critique la dépense pour une roue décorative ; Hélène Fabre répond que la fréquentation de la médiathèque (400 visiteurs/semaine) tranchera le débat.",
      "resolved_order": 3,
      "resolved_days": null
    },
    {
      "id": 5,
      "chunk_index": 4,
      "seq": 0,
      "summary": "Avis nuancé sur le chantier : Delmas & Fils embauche sept apprentis de Céredac, nomination de la bibliothécaire Sophie Vasseur qui dirige une équipe de six personnes et promet une salle enfants au rez‑de‑chaussée ainsi qu’un fonds ancien à l’étage sous la charpente d’origine.",
      "resolved_order": 4,
      "resolved_days": null
    },
    {
      "id": 6,
      "chunk_index": 5,
      "seq": 0,
      "summary": "Le conseil municipal décide de nommer l’équipement « médiathèque Raymond‑Fabre » (contre le souhait de l’association Les Amis du Vieux Moulin), Hélène Fabre maintient le vote, Julien Roche ironise sur la famille qui se donne un bâtiment ; annonce de l’inauguration du 14 juin suivie d’une semaine portes ouvertes et la Sorgue continue de faire tourner la roue décorative.",
      "resolved_order": 5,
      "resolved_days": null
    }
  ],
