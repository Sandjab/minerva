  "moments": [
    {
      "id": 1,
      "chunk_index": 0,
      "seq": 0,
      "summary": "Deux Mercier, le docteur Étienne et la libraire Camille, se partagent la place de l'Église à Aubières.",
      "resolved_order": 0,
      "resolved_days": 0.0
    },
    {
      "id": 2,
      "chunk_index": 1,
      "seq": 0,
      "summary": "Camille Mercier est amie de l’institutrice Suzanne Vidal, surnommée la Demoiselle ; celle‑ci passe les jeudis à la librairie pour corriger des cahiers près du poêle, tandis que le docteur Étienne Mercier la trouve trop pâle et lui recommande de prendre l’air.",
      "resolved_order": 1,
      "resolved_days": null
    },
    {
      "id": 3,
      "chunk_index": 2,
      "seq": 0,
      "summary": "Présentation du domaine de Delorme à Aubières, activités de Lucien Delorme (élevage de chèvres, pressage de cidre) et fourniture du lait que le docteur Étienne Mercier commande pour ses convalescents ; le domaine ne ferme jamais, même l’hiver.",
      "resolved_order": 2,
      "resolved_days": null
    },
    {
      "id": 4,
      "chunk_index": 3,
      "seq": 0,
      "summary": "Un soir de novembre, Suzanne Vidal tousse fortement en classe ; Camille Mercier appelle le docteur Étienne Mercier, qui l’ausculte, lui prescrit un mois de repos au domaine de Delorme et la conduit‑là dans la charrette de Lucien Delorme.",
      "resolved_order": 3,
      "resolved_days": null
    },
    {
      "id": 5,
      "chunk_index": 3,
      "seq": 1,
      "summary": "Au printemps, Suzanne Vidal rouvre la classe guérie ; Camille Mercier et Étienne Mercier, chacun d’un côté de la place, se félicitent comme une même famille.",
      "resolved_order": 4,
      "resolved_days": null
    }
  ],
