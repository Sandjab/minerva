  "moments": [
    {
      "id": 1,
      "chunk_index": 0,
      "seq": 0,
      "summary": "Ce matin, dans son atelier de lutherie à la rue des Grilles, Élise Chardon rencontre le garçon Bastien Malot qui demande à devenir apprenti ; elle lui tend une gouge.",
      "resolved_order": 1,
      "resolved_days": null
    },
    {
      "id": 2,
      "chunk_index": 1,
      "seq": 0,
      "summary": "Élise se rappelle l’hiver de ses douze ans chez son grand‑père Aurélien Chardon, où il lui offre un canif de buis.",
      "resolved_order": 0,
      "resolved_days": 0.0
    },
    {
      "id": 3,
      "chunk_index": 1,
      "seq": 1,
      "summary": "Bastien, nerveux, fende une volute ; Élise ramasse les morceaux et pose le canif de buis sur l’établi entre eux deux.",
      "resolved_order": 2,
      "resolved_days": null
    },
    {
      "id": 4,
      "chunk_index": 2,
      "seq": 0,
      "summary": "Élise Chardon, cinquante ans, ferme pour la dernière fois la porte de la rue des Grilles ; Bastien Malot, devenu maître luthier, reprend l’atelier d’Aubervilliers, reçoit le canif d’Aurélien sur l’établi avec un mot et prend le train pour Mirecourt.",
      "resolved_order": 3,
      "resolved_days": null
    },
    {
      "id": 5,
      "chunk_index": 2,
      "seq": 1,
      "summary": "À Lyon, l’archetière Camille Roche décachette une lettre de Bastien proposant une association entre ses archets et les violons de la rue des Grilles ; elle regarde la Saône depuis son atelier de la Croix‑Rousse et répond qu’elle arrivera au printemps.",
      "resolved_order": 4,
      "resolved_days": null
    }
  ],
