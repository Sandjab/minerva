  "moments": [
    {
      "id": 1,
      "chunk_index": 0,
      "seq": 0,
      "summary": "Élise Chardon accueille Bastien Malot, garçon de seize ans envoyé par l'école Boulle, dans son atelier de lutherie où elle lui tend une gouge.",
      "resolved_order": 1,
      "resolved_days": null
    },
    {
      "id": 2,
      "chunk_index": 1,
      "seq": 0,
      "summary": "Flashback à l’hiver de ses douze ans, Élise chez son grand‑père Aurélien Chardon qui lui offre un canif.",
      "resolved_order": 0,
      "resolved_days": 0.0
    },
    {
      "id": 3,
      "chunk_index": 1,
      "seq": 1,
      "summary": "Retour au présent, Élise interagit avec Bastien qui vient de fendre une volute ; elle ramasse les morceaux et pose le canif sur l’établi.",
      "resolved_order": 2,
      "resolved_days": null
    },
    {
      "id": 4,
      "chunk_index": 2,
      "seq": 0,
      "summary": "Vingt ans plus tard, Élise Chardon (50 ans) ferme la porte de la rue des Grilles, laisse le canif d’Aurélien sur l’établi à Bastien Malot qui reprend l’atelier d’Aubervilliers, puis prend le train pour Mirecourt.",
      "resolved_order": 3,
      "resolved_days": null
    },
    {
      "id": 5,
      "chunk_index": 2,
      "seq": 1,
      "summary": "Au même moment, à Lyon, l’archetière Camille Roche reçoit une lettre de Bastien Malot proposant une association entre ses archets et les violons de la rue des Grilles ; elle regarde la Saône depuis son atelier de la Croix‑Rousse et répond qu’elle arrivera au printemps.",
      "resolved_order": 4,
      "resolved_days": null
    }
  ],
