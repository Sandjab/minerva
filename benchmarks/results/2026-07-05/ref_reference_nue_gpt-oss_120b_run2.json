  "moments": [
    {
      "id": 1,
      "chunk_index": 0,
      "seq": 0,
      "summary": "Antoine Sérac arrive à Valsonne, loue une remise et reçoit la commande d’une carte du mont Chauvel.",
      "resolved_order": 0,
      "resolved_days": 0.0
    },
    {
      "id": 2,
      "chunk_index": 1,
      "seq": 0,
      "summary": "Marguerite Aubanel tient la librairie du Méridien à la place aux Herbes, met de côté des atlas anciens et récits de voyage pour Antoine Sérac ; son frère cadet Lucien Aubanel devient apprenti sous la tutelle d’Antoine Sérac.",
      "resolved_order": 1,
      "resolved_days": null
    },
    {
      "id": 3,
      "chunk_index": 2,
      "seq": 0,
      "summary": "Le commissaire Félix Brossard observe le cartographe et exprime son aversion pour les hommes sans passé.",
      "resolved_order": 3,
      "resolved_days": null
    },
    {
      "id": 4,
      "chunk_index": 2,
      "seq": 1,
      "summary": "Flashback dix ans plus tôt : effondrement du pont de la Frène à Saint‑Elme, le géomètre dont les relevés truqués sont jugés responsables, condamné, purge sa peine puis se volatilise.",
      "resolved_order": 2,
      "resolved_days": null
    },
    {
      "id": 5,
      "chunk_index": 3,
      "seq": 0,
      "summary": "Irène Vaneau, archiviste à Besançon, ouvre le dossier de Théo Rivière, découvre qu’il a retiré une malle d’instruments de cuivre à sa libération et écrit au frère Paul puis au commissaire Félix Brossard.",
      "resolved_order": 4,
      "resolved_days": null
    },
    {
      "id": 6,
      "chunk_index": 4,
      "seq": 0,
      "summary": "Margot tombe malade, le docteur Vaneau la soigne ; Sérac vient à son chevet et lui révèle qu’il s’appelle réellement Théo Rivière.",
      "resolved_order": 5,
      "resolved_days": null
    },
    {
      "id": 7,
      "chunk_index": 5,
      "seq": 0,
      "summary": "Brossard convoque le cartographe, lui remet le dossier Rivière et Sérac montre la carte du mont Chauvel en proposant une vérification par la Société de géographie.",
      "resolved_order": 6,
      "resolved_days": null
    },
    {
      "id": 8,
      "chunk_index": 5,
      "seq": 1,
      "summary": "Au printemps, la Société de géographie renvoie la carte sans correction ; Brossard classe le dossier et fait graver la carte avec la double signature A. Sérac – Th. Rivière.",
      "resolved_order": 7,
      "resolved_days": null
    }
  ],
