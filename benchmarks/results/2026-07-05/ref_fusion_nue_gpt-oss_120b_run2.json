  "moments": [
    {
      "id": 1,
      "chunk_index": 0,
      "seq": 0,
      "summary": "À Aubières, les deux Mercier – le docteur Étienne et la libraire Camille – se partagent la place de l'Église et leurs activités quotidiennes, tandis qu'un facteur remet les lettres adressées à « Mercier » d'abord à Camille puis éventuellement à Étienne.",
      "resolved_order": 0,
      "resolved_days": 0.0
    },
    {
      "id": 2,
      "chunk_index": 1,
      "seq": 0,
      "summary": "Suzanne Vidal, amie de Camille, passe ses jeudis à la librairie à corriger des cahiers; le docteur Étienne Mercier la trouve trop pâle et lui conseille de prendre l’air.",
      "resolved_order": 1,
      "resolved_days": null
    },
    {
      "id": 3,
      "chunk_index": 2,
      "seq": 0,
      "summary": "Le domaine de Delorme à Aubières est présenté ; Lucien Delorme élève des chèvres, presse du cidre et fournit le lait que le docteur Étienne Mercier sert à ses convalescents. Le domaine ne ferme jamais, même en hiver.",
      "resolved_order": 2,
      "resolved_days": null
    },
    {
      "id": 4,
      "chunk_index": 3,
      "seq": 0,
      "summary": "Un soir de novembre, la Demoiselle tousse en classe ; le docteur Étienne Mercier l’ausculte, lui prescrit un mois de repos au Domaine de Delorme et Lucien Delorme la conduit là‑bas.",
      "resolved_order": 3,
      "resolved_days": null
    },
    {
      "id": 5,
      "chunk_index": 3,
      "seq": 1,
      "summary": "Au printemps, Mlle Vidal rouvre la classe guérie ; Étienne et Camille Mercier se félicitent comme s’ils étaient de la même famille.",
      "resolved_order": 4,
      "resolved_days": null
    }
  ],
