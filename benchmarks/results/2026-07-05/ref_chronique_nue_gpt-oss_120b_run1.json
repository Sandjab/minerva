  "moments": [
    {
      "id": 1,
      "chunk_index": 0,
      "seq": 0,
      "summary": "Ouverture de la médiathèque du Vieux Moulin le 14 juin après trois ans de travaux et deux reports.",
      "resolved_order": 1,
      "resolved_days": null
    },
    {
      "id": 2,
      "chunk_index": 1,
      "seq": 0,
      "summary": "Sauvetage du Vieux Moulin par l'association Les Amis du Vieux Moulin et rachat du bâtiment par la municipalité après dix ans de pétitions.",
      "resolved_order": 0,
      "resolved_days": 0.0
    },
    {
      "id": 3,
      "chunk_index": 2,
      "seq": 0,
      "summary": "Attribution de la réhabilitation du Vieux Moulin à l'architecte Nadia Berthelot, conservation de la grande roue à aubes derrière une paroi de verre, coût du chantier mené par Delmas & Fils avec un tiers versé par la Région, et citation de Berthelot sur le parti‑pris de la médiathèque.",
      "resolved_order": 2,
      "resolved_days": null
    },
    {
      "id": 4,
      "chunk_index": 3,
      "seq": 0,
      "summary": "Débat au conseil municipal : Julien Roche vote contre le budget final et critique le coût de la roue décorative, la maire Hélène Fabre réplique en évoquant une fréquentation estimée à 400 visiteurs par semaine.",
      "resolved_order": 3,
      "resolved_days": null
    },
    {
      "id": 5,
      "chunk_index": 4,
      "seq": 0,
      "summary": "Nuances à la place du Marché : embauche d’apprentis, nouvelle bibliothécaire et promesses d’espaces enfants/fonds anciens.",
      "resolved_order": 4,
      "resolved_days": null
    },
    {
      "id": 6,
      "chunk_index": 5,
      "seq": 0,
      "summary": "Le conseil municipal décide, mardi, d’appeler la médiathèque « médiathèque Raymond‑Fabre », contre le souhait de l’association ; Julien Roche ironise, Céredac note la différence entre meunier et maire. L’inauguration est prévue le 14 juin suivie d’une semaine de portes ouvertes et la Sorgue continue à faire tourner la grande roue à aubes pour le décor.",
      "resolved_order": 5,
      "resolved_days": null
    }
  ],
