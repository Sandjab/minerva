  "moments": [
    {
      "id": 1,
      "chunk_index": 0,
      "seq": 0,
      "summary": "Antoine Sérac arrive à Valsonne, s’installe dans une remise de la rue des Tanneurs, ouvre un atelier et reçoit d’une commande de la Société de géographie de Valsonne pour une carte du mont Chauvel.",
      "resolved_order": 0,
      "resolved_days": 0.0
    },
    {
      "id": 2,
      "chunk_index": 1,
      "seq": 0,
      "summary": "Marguerite Aubanel tient la librairie du Méridien, met de côté des atlas pour Antoine Sérac qui vient les chercher chaque samedi, et prend son frère cadet Lucien Aubanel comme apprenti à l’atelier de cartographie.",
      "resolved_order": 1,
      "resolved_days": null
    },
    {
      "id": 3,
      "chunk_index": 2,
      "seq": 0,
      "summary": "Le commissaire Félix Brossard critique le cartographe et se souvient d’un événement passé.",
      "resolved_order": 3,
      "resolved_days": null
    },
    {
      "id": 4,
      "chunk_index": 2,
      "seq": 1,
      "summary": "Flashback : dix ans plus tôt, l’effondrement du pont de la Frène à Saint‑Elme et le géomètre responsable condamné.",
      "resolved_order": 2,
      "resolved_days": null
    },
    {
      "id": 5,
      "chunk_index": 3,
      "seq": 0,
      "summary": "Irène Vaneau découvre le dossier de Théo Rivière à Besançon, apprend qu’il a retiré une malle d’instruments de cuivre à sa libération et informe son frère Paul Vaneau puis écrit au commissaire Félix Brossard sur son conseil.",
      "resolved_order": 4,
      "resolved_days": null
    },
    {
      "id": 6,
      "chunk_index": 4,
      "seq": 0,
      "summary": "En hiver, Marguerite (Margot) est alitée une semaine après avoir attrapé froid ; le docteur Irène Vaneau la soigne, trouve Antoine Sérac à son chevet qui lui révèle qu’il s’appelle réellement Théo Rivière et a usurpé son identité.",
      "resolved_order": 5,
      "resolved_days": null
    },
    {
      "id": 7,
      "chunk_index": 5,
      "seq": 0,
      "summary": "En janvier, la lettre provenant de Besançon arrive ; le commissaire Félix Brossard convoque le cartographe Antoine Sérac, lui dépose le dossier Rivière et celui‑ci propose que la carte achevée du mont Chauvel soit vérifiée point par point par la Société de géographie de Valsonne.",
      "resolved_order": 6,
      "resolved_days": null
    },
    {
      "id": 8,
      "chunk_index": 5,
      "seq": 1,
      "summary": "Au printemps, la carte revient sans aucune correction ; le commissaire Félix Brossard classe de sa propre main le dossier Rivière, fait graver la carte et y appose la double signature « A. Sérac — Th. Rivière ».",
      "resolved_order": 7,
      "resolved_days": null
    }
  ],
