  "moments": [
    {
      "id": 1,
      "chunk_index": 0,
      "seq": 0,
      "summary": "Antoine Sérac s’installe à Valsonne, loue une remise et ouvre un atelier de cartographie ; la Société de géographie de Valsonne lui commande une carte des hauteurs du mont Chauvel.",
      "resolved_order": 0,
      "resolved_days": 0.0
    },
    {
      "id": 2,
      "chunk_index": 1,
      "seq": 0,
      "summary": "Marguerite Aubanel gère la librairie du Méridien, met de côté pour Sérac des atlas anciens et des récits de voyage que celui‑ci vient chercher les samedis; le frère cadet Lucien devient apprenti chez Sérac au printemps.",
      "resolved_order": 1,
      "resolved_days": null
    },
    {
      "id": 3,
      "chunk_index": 2,
      "seq": 0,
      "summary": "Le commissaire Félix Brossard exprime son aversion pour les hommes sans passé et relève que le cartographe Antoine Sérac ne parle jamais de ses années de formation.",
      "resolved_order": 3,
      "resolved_days": null
    },
    {
      "id": 4,
      "chunk_index": 2,
      "seq": 1,
      "summary": "Flashback : dix ans plus tôt, tout la province parle de l’effondrement du pont de la Frène à Saint‑Elme et d’un géomètre tenu responsable, condamné, qui purge sa peine puis disparaît.",
      "resolved_order": 2,
      "resolved_days": null
    },
    {
      "id": 5,
      "chunk_index": 3,
      "seq": 0,
      "summary": "Irène Vaneau, à Besançon, classe les minutes du tribunal, découvre le dossier de Théo Rivière, note qu’il a retiré une malle d’instruments à sa libération et écrit à son frère Paul puis au commissaire Félix Brossard.",
      "resolved_order": 4,
      "resolved_days": null
    },
    {
      "id": 6,
      "chunk_index": 4,
      "seq": 0,
      "summary": "Cet hiver‑là Marguerite (Margot) tombe malade, est soignée par le docteur Vaneau; Antoine Sérac apparaît à son chevet et révèle être Théo Rivière, gardant ce secret.",
      "resolved_order": 5,
      "resolved_days": null
    },
    {
      "id": 7,
      "chunk_index": 5,
      "seq": 0,
      "summary": "Félix Brossard convoque le cartographe Antoine Sérac, lui présente le dossier Rivière et la carte achevée du Mont Chauvel ; il fait vérifier la carte par la Société de géographie, puis au printemps la classe et la fait graver, ajoutant la double signature A. Sérac — Th. Rivière.",
      "resolved_order": 6,
      "resolved_days": null
    }
  ],
