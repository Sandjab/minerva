  "moments": [
    {
      "id": 1,
      "chunk_index": 0,
      "seq": 0,
      "summary": "Élise Chardon accueille Bastien Malot, qui vient de l’école Boulle demander à devenir son apprenti, et elle lui tend une gouge.",
      "resolved_order": 1,
      "resolved_days": null
    },
    {
      "id": 2,
      "chunk_index": 1,
      "seq": 0,
      "summary": "Flashback : Élise revit l’hiver de ses douze ans dans la maison de son grand‑père, le luthier Aurélien Chardon, à Mirecourt.",
      "resolved_order": 0,
      "resolved_days": 0.0
    },
    {
      "id": 3,
      "chunk_index": 1,
      "seq": 1,
      "summary": "Retour au présent dans l’atelier : Bastien, trop nerveux, vient de fendre une volute; Élise ramasse les morceaux et pose le canif de buis sur l’établi entre eux deux.",
      "resolved_order": 2,
      "resolved_days": null
    },
    {
      "id": 4,
      "chunk_index": 2,
      "seq": 0,
      "summary": "Vingt ans plus tard, Élise (50 ans) ferme la porte de la rue des Grilles, laisse le canif d’Aurélien sur l’établi, Bastien reprend l’atelier d’Aubervilliers, puis elle prend le train pour Mirecourt où l’attend la maison de son enfance.",
      "resolved_order": 3,
      "resolved_days": null
    },
    {
      "id": 5,
      "chunk_index": 2,
      "seq": 1,
      "summary": "Au même moment, à Lyon, Camille Roche déchache la lettre de Bastien proposant une association, regarde la Saône depuis son atelier de la Croix‑Rousse et répond qu’elle arrivera au printemps.",
      "resolved_order": 4,
      "resolved_days": null
    }
  ],
