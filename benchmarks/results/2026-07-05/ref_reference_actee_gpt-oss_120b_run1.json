  "moments": [
    {
      "id": 1,
      "chunk_index": 0,
      "seq": 0,
      "summary": "Antoine Sérac s’installe à Valsonne, ouvre un atelier de cartographie dans une ancienne remise et reçoit la commande d’une carte du mont Chauvel.",
      "resolved_order": 0,
      "resolved_days": 0.0
    },
    {
      "id": 2,
      "chunk_index": 1,
      "seq": 0,
      "summary": "Marguerite Aubanel dirige la librairie du Méridien à place aux Herbes, met de côté des atlas anciens pour Antoine Sérac qui vient les chercher le samedi ; son frère Lucien devient apprenti chez Sérac au printemps et apprend à tendre le papier puis à tenir la plume.",
      "resolved_order": 1,
      "resolved_days": null
    },
    {
      "id": 3,
      "chunk_index": 2,
      "seq": 0,
      "summary": "Félix Brossard critique le manque de passé d’Antoine Sérac.",
      "resolved_order": 3,
      "resolved_days": null
    },
    {
      "id": 4,
      "chunk_index": 2,
      "seq": 1,
      "summary": "Flashback : dix ans plus tôt, effondrement du pont de la Frène et condamnation d’Antoine Sérac pour ses relevés truqués.",
      "resolved_order": 2,
      "resolved_days": null
    },
    {
      "id": 5,
      "chunk_index": 3,
      "seq": 0,
      "summary": "Irène Vaneau, à Besançon, découvre le dossier du géomètre condamné Théo Rivière qui avait retiré une malle d'instruments de cuivre ; elle en informe son frère Paul Vaneau puis écrit au commissaire Félix Brossard.",
      "resolved_order": 4,
      "resolved_days": null
    },
    {
      "id": 6,
      "chunk_index": 4,
      "seq": 0,
      "summary": "Marguerite Aubanel (Margot) est alitée un hiver, le docteur Paul Vaneau la soigne, et Antoine Sérac lui avoue être Théo Rivière avant de repartir sous son nom d’emprunt.",
      "resolved_order": 5,
      "resolved_days": null
    },
    {
      "id": 7,
      "chunk_index": 5,
      "seq": 0,
      "summary": "Arrivée de la lettre de Besançon en janvier ; Félix Brossard convoque Antoine Sérac et lui montre le dossier Rivière.",
      "resolved_order": 6,
      "resolved_days": null
    },
    {
      "id": 8,
      "chunk_index": 5,
      "seq": 1,
      "summary": "Au printemps, la Société de géographie vérifie la carte sans aucune correction ; Brossard classe le dossier et la carte est gravée avec une double signature « A. Sérac — Th. Rivière ».",
      "resolved_order": 7,
      "resolved_days": null
    }
  ],
