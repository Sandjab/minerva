  "moments": [
    {
      "id": 1,
      "chunk_index": 0,
      "seq": 0,
      "summary": "À Aubières, le docteur Étienne Mercier et la libraire Camille Mercier exercent chacun son métier près de l’Église.",
      "resolved_order": 0,
      "resolved_days": 0.0
    },
    {
      "id": 2,
      "chunk_index": 1,
      "seq": 0,
      "summary": "Camille Mercier est amie de l’institutrice Suzanne Vidal, surnommée la Demoiselle, qui passe ses jeudis à la librairie à corriger des cahiers près du poêle ; le docteur Étienne Mercier la trouve trop pâle et lui recommande l’air frais.",
      "resolved_order": 1,
      "resolved_days": null
    },
    {
      "id": 3,
      "chunk_index": 2,
      "seq": 0,
      "summary": "Présentation du domaine de Delorme à Aubières, activités de Lucien Delorme et sa fourniture de lait au docteur Étienne Mercier.",
      "resolved_order": 2,
      "resolved_days": null
    },
    {
      "id": 4,
      "chunk_index": 3,
      "seq": 0,
      "summary": "Un soir de novembre, la Demoiselle tousse fortement en classe ; Camille Mercier appelle le docteur Étienne Mercier qui l’ausculte, lui prescrive un mois de repos au Domaine de Delorme et Lucien Delorme la conduit là dans sa charrette.",
      "resolved_order": 3,
      "resolved_days": null
    },
    {
      "id": 5,
      "chunk_index": 3,
      "seq": 1,
      "summary": "Au printemps, Mlle Vidal rouvre la classe guérie ; les deux Mercier se félicitent de sa guérison comme s’ils étaient de la même famille.",
      "resolved_order": 4,
      "resolved_days": null
    }
  ],
