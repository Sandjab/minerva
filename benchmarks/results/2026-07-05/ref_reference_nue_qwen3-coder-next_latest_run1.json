  "moments": [
    {
      "id": 1,
      "chunk_index": 0,
      "seq": 0,
      "summary": "Arrivée d’Antoine Sérac à Valsonne trois ans plus tôt et installation de son atelier de cartographie, suivie de la commande d’une carte par la Société de géographie.",
      "resolved_order": 0,
      "resolved_days": 0.0
    },
    {
      "id": 2,
      "chunk_index": 1,
      "seq": 0,
      "summary": "Rencontre et collaboration entre Antoine Sérac et Margot Aubanel (Marguerite), ainsi que l’embauche de son frère Lucien comme apprenti.",
      "resolved_order": 1,
      "resolved_days": null
    },
    {
      "id": 3,
      "chunk_index": 2,
      "seq": 0,
      "summary": "Le commissaire Brossard exprime ses soupçons sur le passé mystérieux d'Antoine Sérac et évoque un événement vieux de dix ans : l'effondrement du pont de la Frène à Saint-Elme, lié à des relevés truqués par un géomètre condamné disparu.",
      "resolved_order": 2,
      "resolved_days": null
    },
    {
      "id": 4,
      "chunk_index": 3,
      "seq": 0,
      "summary": "Irène Vaneau découvre意外ment le dossier de Théo Rivière à Besançon et en informe son frère puis le commissaire Brossard.",
      "resolved_order": 3,
      "resolved_days": null
    },
    {
      "id": 5,
      "chunk_index": 4,
      "seq": 0,
      "summary": "Margot Aubanel tombe malade à l’hiver, Sérac lui lit un portulan, puis lui avoue son identité passée de Théo Rivière et les circonstances de sa fuite sous une fausse identité.",
      "resolved_order": 4,
      "resolved_days": null
    },
    {
      "id": 6,
      "chunk_index": 5,
      "seq": 0,
      "summary": "Le commissaire Brossard expose à Sérac le dossier de Théo Rivière ; Sérac ne nie pas, mais oppose la carte du mont Chauvel achevée et officiellement validée comme preuve de sa réhabilitation.",
      "resolved_order": 5,
      "resolved_days": null
    }
  ],
