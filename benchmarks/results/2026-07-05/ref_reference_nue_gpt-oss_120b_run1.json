  "moments": [
    {
      "id": 1,
      "chunk_index": 0,
      "seq": 0,
      "summary": "Antoine Sérac arrive à Valsonne, loue une remise, ouvre un atelier de cartographie et reçoit la commande d’une carte des hauteurs du mont Chauvel.",
      "resolved_order": 0,
      "resolved_days": 0.0
    },
    {
      "id": 2,
      "chunk_index": 1,
      "seq": 0,
      "summary": "Marguerite Aubanel tient la librairie du Méridien, met de côté des atlas anciens et récits de voyage pour Antoine Sérac qui vient les chercher le samedi; son frère cadet Lucien devient apprenti à l’atelier de cartographie où Sérac lui enseigne la technique du papier et de la plume.",
      "resolved_order": 1,
      "resolved_days": null
    },
    {
      "id": 3,
      "chunk_index": 2,
      "seq": 0,
      "summary": "Le commissaire Félix Brossard critique le cartographe Antoine Sérac pour son absence de passé déclaré.",
      "resolved_order": 3,
      "resolved_days": null
    },
    {
      "id": 4,
      "chunk_index": 2,
      "seq": 1,
      "summary": "Flash‑back : dix ans plus tôt, l’effondrement du pont de la Frène à Saint‑Elme et le géomètre responsable condamné puis disparu.",
      "resolved_order": 2,
      "resolved_days": null
    },
    {
      "id": 5,
      "chunk_index": 3,
      "seq": 0,
      "summary": "À Besançon, Irène Vaneau retrouve le dossier du géomètre Théo Rivière, apprend qu’il a retiré une malle d’instruments de cuivre à sa libération, écrit à son frère le docteur Paul Vaneau puis, sur ses conseils, adresse une lettre au commissaire Félix Brossard.",
      "resolved_order": 4,
      "resolved_days": null
    },
    {
      "id": 6,
      "chunk_index": 4,
      "seq": 0,
      "summary": "Marguerite Aubanel tombe malade en plein hiver, reste alitée une semaine ; le docteur Paul Vaneau la soigne, et Antoine Sérac, qui se révèle être Théo Rivière, lui lit un portulan au chevet, révélant son identité qu’elle garde secrète.",
      "resolved_order": 5,
      "resolved_days": null
    },
    {
      "id": 7,
      "chunk_index": 5,
      "seq": 0,
      "summary": "Brossard reçoit la lettre de Besançon en janvier, convoque Sérac qui montre la carte du mont Chauvel, propose sa vérification à la Société de géographie ; au printemps la carte revient sans correction, le dossier est classé et la carte gravée avec la double signature A. Sérac — Th. Rivière.",
      "resolved_order": 6,
      "resolved_days": null
    }
  ],
