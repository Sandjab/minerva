  "moments": [
    {
      "id": 1,
      "chunk_index": 0,
      "seq": 0,
      "summary": "Elise Chardon accueille Bastien Malot, qui arrive le matin pour demander un apprentissage dans son atelier de lutherie.",
      "resolved_order": 1,
      "resolved_days": null
    },
    {
      "id": 2,
      "chunk_index": 1,
      "seq": 0,
      "summary": "Flashback : Élise se souvient de l’hiver de ses douze ans chez son grand‑père Aurélien, où il lui offre son premier canif.",
      "resolved_order": 0,
      "resolved_days": 0.0
    },
    {
      "id": 3,
      "chunk_index": 1,
      "seq": 1,
      "summary": "Retour au présent : Bastien, encore nerveux après avoir fendu une volute, voit Élise placer le canif sur l’établi entre eux.",
      "resolved_order": 2,
      "resolved_days": null
    },
    {
      "id": 4,
      "chunk_index": 2,
      "seq": 0,
      "summary": "Vingt ans plus tard, Élise ferme pour la dernière fois la porte du  rue des Grilles, transmet le canif d’Aurélien à Bastien qui reprend l’atelier, puis prend le train pour Mirecourt.",
      "resolved_order": 3,
      "resolved_days": null
    },
    {
      "id": 5,
      "chunk_index": 2,
      "seq": 1,
      "summary": "Au même moment, à Lyon, Camille Roche décachette la lettre de Bastien proposant une association ; elle regarde la Saône depuis son atelier de la Croix‑Rousse et promet d’arriver au printemps.",
      "resolved_order": 4,
      "resolved_days": null
    }
  ],
