  "moments": [
    {
      "id": 1,
      "chunk_index": 0,
      "seq": 0,
      "summary": "Élise Chardon travaille dans son atelier de lutherie à la rue des Grilles quand Bastien Malot, 16 ans, envoyé par l’école Boulle, arrive pour demander un apprentissage et elle lui tend une gouge sans parler.",
      "resolved_order": 1,
      "resolved_days": null
    },
    {
      "id": 2,
      "chunk_index": 1,
      "seq": 0,
      "summary": "Flashback d'Élise à l'hiver de ses douze ans dans la maison de son grand‑père Aurélien Chardon à Mirecourt.",
      "resolved_order": 0,
      "resolved_days": 0.0
    },
    {
      "id": 3,
      "chunk_index": 1,
      "seq": 1,
      "summary": "Retour au présent : Bastien, trop nerveux, fendt une volute ; Élise ramasse les morceaux et repose le canif sur l'établi entre eux.",
      "resolved_order": 2,
      "resolved_days": null
    },
    {
      "id": 4,
      "chunk_index": 2,
      "seq": 0,
      "summary": "Vingt ans plus tard, Élise (50 ans) ferme la porte du 8 rue des Grilles ; Bastien reprend l'atelier d'Aubervilliers. Elle laisse le canif d'Aurélien sur l'établi avec un mot et prend le train pour Mirecourt où l'attend sa maison d'enfance.",
      "resolved_order": 3,
      "resolved_days": null
    },
    {
      "id": 5,
      "chunk_index": 2,
      "seq": 1,
      "summary": "Au même moment, à Lyon, l'archetière Camille Roche décachette la lettre de Bastien proposant un partenariat entre ses archets et les violons de la rue des Grilles ; elle regarde la Saône depuis son atelier de la Croix‑Rousse et répond qu'elle arrivera au printemps.",
      "resolved_order": 4,
      "resolved_days": null
    }
  ],
